<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Zoom Pro Clone</title>
  <link rel="stylesheet" href="style.css">
  <script src="/socket.io/socket.io.js" defer></script>
  <script src="https://unpkg.com/peerjs@1.3.1/dist/peerjs.min.js" defer></script>
  <script>const ROOM_ID = "<%= roomId %>";</script>
  <script src="script.js" defer></script>
</head>
<body>
  <div class="main">
    <div class="main__left">
      <div class="main__videos"><div id="video-grid"></div></div>
      <div class="main__controls">
        <div class="main__controls__block">
          <div class="main__controls__button"><span>Mute</span></div>
          <div class="main__controls__button"><span>Stop Video</span></div>
        </div>
        <div class="main__controls__block">
          <div onclick="shareScreen()" class="main__controls__button"><span>Share Screen</span></div>
          <div class="main__controls__button"><span>Participants</span></div>
          <div onclick="toggleChat()" class="main__controls__button"><span>Chat</span></div>
        </div>
        <div class="main__controls__block">
          <div class="main__controls__button"><span>Leave</span></div>
        </div>
      </div>
    </div>
    <div class="main__right">
       <div class="main__header"><h6>Chat</h6></div>
       <div class="main__chat_window"><ul class="messages"></ul></div>
       <div class="main__message_container">
         <input id="chat_message" type="text" placeholder="Type message...">
       </div>
    </div>
  </div>
</body>
</html>